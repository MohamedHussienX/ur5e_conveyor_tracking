<?xml version="1.0"?>
<robot name="smart_box">
  <link name="box_base">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.06"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
    
    <collision>
      <geometry>
        <cylinder radius="0.025" length="0.06"/>
      </geometry>
    </collision>
  </link>
  
  <gazebo reference="box_base"> 
    <material>Gazebo/Blue</material>
    <mu1>1000.0</mu1>
    <mu2>1000.0</mu2>
    <kp>100000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.005</minDepth>
    <maxVel>0.0</maxVel>
  </gazebo>

  <gazebo>
    <plugin name="box_movement" filename="libgazebo_ros_planar_move.so">
      <ros>
        <remapping>cmd_vel:=/box_cmd_vel</remapping>
      </ros>
      <update_rate>50</update_rate>
      <publish_odom>false</publish_odom>
      <publish_tf>false</publish_tf>
      <robot_base_frame>box_base</robot_base_frame>
    </plugin>
  </gazebo>
</robot>